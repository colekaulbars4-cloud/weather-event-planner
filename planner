      "source": [
        "# --- LET THE USER TYPE ANY CITY ---\n",
        "\n",
        "city = input(\"Enter a city (e.g. 'Chicago' or 'Chicago, IL'): \")\n",
        "\n",
        "geo_url = \"https://geocoding-api.open-meteo.com/v1/search\"\n",
        "geo_params = {\"name\": city, \"count\": 1}\n",
        "\n",
        "geo_response = requests.get(geo_url, params=geo_params)\n",
        "geo_data = geo_response.json()\n",
        "\n",
        "if \"results\" not in geo_data:\n",
        "    print(f\"Couldn't find a location called '{city}'. Try being more specific.\")\n",
        "else:\n",
        "    result = geo_data[\"results\"][0]\n",
        "    latitude = result[\"latitude\"]\n",
        "    longitude = result[\"longitude\"]\n",
        "    found_name = result[\"name\"]\n",
        "    found_region = result.get(\"admin1\", \"\")\n",
        "    found_country = result[\"country\"]\n",
        "    print(f\"Found: {found_name}, {found_region}, {found_country}\")\n",
        "    print(f\"Coordinates: {latitude}, {longitude}\")"
      ],
      "metadata": {
