        "# --- FLAG GOOD DAYS FOR AN OUTDOOR VOLUNTEER EVENT ---\n",
        "\n",
        "def is_good_day(row):\n",
        "    # Good day = not too hot, low rain chance, not too windy\n",
        "    if row[\"high_F\"] > 95:\n",
        "        return \"Too hot\"\n",
        "    if row[\"rain_chance_%\"] > 40:\n",
        "        return \"Rain risk\"\n",
        "    if row[\"max_wind_mph\"] > 20:\n",
        "        return \"Too windy\"\n",
        "    return \"Good to go\"\n",
        "\n",
        "forecast[\"event_status\"] = forecast.apply(is_good_day, axis=1)\n",
        "print(forecast[[\"date\", \"high_F\", \"rain_chance_%\", \"max_wind_mph\", \"event_status\"]])"
      ],
