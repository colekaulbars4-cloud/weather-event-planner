        "    \"temperature_unit\": \"fahrenheit\",\n",
        "    \"timezone\": \"America/New_York\"\n",
        "}\n",
        "\n",
        "response = requests.get(url, params=params)\n",
        "data = response.json()\n",
        "\n",
        "print(\"Status code:\", response.status_code)\n",
        "print(data)"
